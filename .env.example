# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — never commit real secrets.

# Anthropic API key (used from Phase 1 / F1.6 onward for answer generation).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Claude model to use for answer generation.
ANTHROPIC_MODEL=claude-sonnet-4-6

# LLM backend (Phase 3). "api" = Anthropic API (default, uses ANTHROPIC_API_KEY);
# "bedrock" = AWS Bedrock (uses the AWS credential chain, no API key needed).
LLM_BACKEND=api
# Bedrock only: region + inference profile. The AU profile keeps data in-country
# (routes within ap-southeast-2 / ap-southeast-4). Requires Bedrock model access
# + the Anthropic use case details form submitted in the console.
AWS_REGION=ap-southeast-2
BEDROCK_MODEL=au.anthropic.claude-sonnet-4-6

# Retrieval backend (Phase 4). "faiss" = local index (default); "kb" = Bedrock
# Knowledge Base (managed retrieval via the Retrieve API; uses AWS_REGION above).
RETRIEVAL_BACKEND=faiss
KB_ID=

# Bedrock Agent (Phase 5) — managed orchestration via InvokeAgent (KB + Guardrail
# attached server-side). Used by bedrock_agent.py; uses AWS_REGION above.
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=TSTALIASID

# Optional: self-hosted Langfuse (Tier-2 trace UI). Leave blank to disable
# (tracing falls back to data/traces/traces.jsonl only). Get keys from the
# Langfuse UI after first boot — see infra/langfuse/README.md.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
